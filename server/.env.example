# Copy to .env (or set in docker-compose) and adjust.

# HTTP
PORT=8080
HOST=0.0.0.0

# Where uploads, outputs and the SQLite DB live. In Docker this is the volume.
DATA_DIR=./data

# Parallel FFmpeg renders. Leave unset to default to the CPU count.
# RENDER_CONCURRENCY=4

# Upload size cap in bytes. 0 = unlimited (removes the old 25MB ceiling).
# Default if unset is 5GB.
MAX_UPLOAD_BYTES=0

# Optional API auth. When set, every /api and /v1 call needs:
#   Authorization: Bearer <token>   (or  X-API-KEY: <token>)
# API_TOKEN=change-me

# Public origin used to build absolute URLs to outputs (set in production).
# PUBLIC_BASE_URL=https://clips.example.com

# Override binaries if not on PATH.
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Default subtitle font (a .ttf path).
# FONT_FILE=/app/assets/fonts/DejaVuSans-Bold.ttf

# ── Stage 2: AI pipeline ─────────────────────────────────────────────────────
# Transcription via Groq Whisper (get a key at https://console.groq.com/keys)
GROQ_API_KEY=
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# AI director via Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
# Model tiers (defaults shown): director=Opus 4.8, research=Sonnet 4.6, fast=Haiku 4.5
# CLAUDE_DIRECTOR_MODEL=claude-opus-4-8
# CLAUDE_RESEARCH_MODEL=claude-sonnet-4-6
# CLAUDE_FAST_MODEL=claude-haiku-4-5

# Optional: Kinovi AI B-roll generation
# ZITE_KINOVI_API_KEY=
# ZITE_KINOVI_BASE_URL=https://api.kinovi.ai
