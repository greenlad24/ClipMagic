{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "comment": "pipeline-entry.ts imports the original app at ../../../src and is built only by esbuild (build:pipeline); the other src/ai/*.ts are tsc-safe and compile to dist/ai for the native vision indexer.",
  "exclude": ["node_modules", "dist", "src/ai/pipeline-entry.ts", "scripts"]
}
